# SMSBridge · 環境變量範本
# 複製為 .env 後填入真實值（.env 不入版本庫）

# Telegram Bot Token —— 在 @BotFather 創建 Bot 後獲取
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# 目標 Chat ID（可多個，逗號分隔）
# 個人：發任意消息給 Bot 後呼叫 getUpdates 取得 chat.id
# 群組：-100 開頭的負數 ID
TELEGRAM_CHAT_IDS=123456789

# 服務器監聽設定
SERVER_HOST=127.0.0.1
SERVER_PORT=8580

# 日誌
LOG_LEVEL=INFO
LOG_FILE=logs/smsbridge.log

# TLS（可選，非本地場景啟用 HTTPS）
# TLS_CERTFILE=server/certs/server.crt
# TLS_KEYFILE=server/certs/server.key

# 內容過濾（可選）
# FILTER_ENABLED=True
# FILTER_KEYWORDS_BLOCK=
# FILTER_REGEX_BLOCK=

# 消息聚合（可選，0=關閉）
# AGGREGATE_WINDOW=0

# 心跳告警（可選，預設 120 秒）
# HEARTBEAT_TIMEOUT=120