# SMSBridge · YAML 配置文件範本
# 與 .env 二選一，優先級：.env > config.yaml

server:
  host: 127.0.0.1
  port: 8580

telegram:
  bot_token: "123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
  chat_ids:
    - 123456789  # 個人 Chat ID
  parse_mode: "HTML"
  disable_web_page_preview: true

filter:
  enabled: true
  keywords_block:
    - "广告"
    - "验证码"
  regex_block: []

aggregate:
  window_seconds: 60

logging:
  level: INFO
  file: logs/smsbridge.log
